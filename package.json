{
  "name": "wilvardo-site",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Personal site de Wilvardo Ramirez. HTML/SCSS/TS vanilla, Vite, sin frameworks de UI.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host",
    "lint": "eslint 'src/**/*.{ts,js}'",
    "format": "prettier --write 'src/**/*.{ts,scss,html,json}'",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@types/three": "^0.184.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "husky": "^9.0.0",
    "prettier": "^3.2.0",
    "sass": "^1.71.0",
    "shiki": "^4.2.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0"
  },
  "dependencies": {
    "gsap": "^3.12.5",
    "three": "^0.163.0",
    "vanilla-tilt": "^1.8.1"
  }
}
